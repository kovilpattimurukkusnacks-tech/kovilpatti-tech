# .NET build outputs
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# IDE
.vs/
.vscode/
.idea/
*.swp

# Local secrets / config (use dotnet user-secrets or env vars)
**/secrets.json
appsettings.*.local.json

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Misc
*.bak
*.tmp

# Frontend lives in its own GitHub repo (shop-to-godown-order-management)
# and is deployed to Vercel from there. This folder is here only for local
# convenience — the outer mono-repo does not track it.
./node_modules/
./dist/
./build/

# One-shot DB scripts — local-dev seeds, resets, and migrations that should
# never be checked into the canonical schema folder. Canonical SQL
# (phase{N}_init / phase{N}_procedures + idempotent addendums) stays tracked
# under DB/phaseN/.
DB/One shot scripts/
